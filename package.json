{
  "name": "buildpact",
  "version": "0.1.0-alpha.5",
  "description": "Open-source Spec-Driven Development framework — bilingual CLI for developers and domain experts",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "buildpact": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "templates",
    "locales"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "buildpact",
    "spec-driven-development",
    "cli",
    "ai",
    "framework",
    "squad",
    "bilingual"
  ],
  "author": "BuildPact Contributors",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsdown": "~0.20.3",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/leoeloys/buildpact.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
