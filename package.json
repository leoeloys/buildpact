{
  "name": "buildpact",
  "version": "2.0.0",
  "private": true,
  "description": "Spec-Driven Development framework — bilingual CLI for developers and domain experts",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "buildpact": "./dist/cli/index.mjs"
  },
  "files": [
    "dist",
    "templates",
    "locales"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "benchmark": "node dist/benchmark/index.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "release:check": "tsx scripts/release-check.ts",
    "release:publish": "tsx scripts/release-publish.ts"
  },
  "keywords": [
    "buildpact",
    "spec-driven-development",
    "cli",
    "ai",
    "framework",
    "squad",
    "bilingual"
  ],
  "author": "BuildPact Contributors",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@clack/prompts": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsdown": "~0.20.3",
    "typescript": "^5.0.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/leoeloys/buildpact.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
